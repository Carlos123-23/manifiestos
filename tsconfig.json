{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "experimentalDecorators": true,
    "target": "ES2019",
    "module": "commonjs",
    "lib": ["es2019", "es2020.bigint", "es2020.string", "es2020.symbol.wellknown"],
    "esModuleInterop": true,
    "outDir": "./app",
    "baseUrl": "./src",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
