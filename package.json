{
  "name": "sur-appcli-customer-identity-access-api",
  "version": "1.0.0",
  "description": "Serivicio para la identificacion del usuario por Tipo de documento",
  "main": "./dist/server/index.js",
  "author": "",
  "system": "darwin-generator-nodejs-system",
  "subSystem": "darwin-generator-nodejs-sub-system",
  "application": "darwin-generator-nodejs-application",
  "subApplication": "subApplication",
  "appKey": "appcli",
  "license": "ISC",
  "scripts": {
    "start": "node ./app/server/index.js || echo ERROR: execute 'npm run build' before start the server",
    "dev": "ts-node-dev --respawn -r dotenv/config ./src/server/index.ts",
    "build": "tsc --build tsconfig.json",
    "lint": "eslint ./**/*.ts",
    "lint:fix": "eslint ./**/*.ts --quiet --fix",
    "precommit": "npm run test:coverage",
    "audit": "npm audit --registry=https://registry.npmjs.org --proxy=http://proxyapps.gsnet.corp:80 --strict-ssl=false",
    "audit:fix": " npm audit fix --force --registry=https://registry.npmjs.org --proxy=http://proxyapps.gsnet.corp:80 --strict-ssl=false",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --detectOpenHandles --forceExit",
    "test:continuous": "cross-env NODE_ENV=test jest --watchAll"
  },
  "engines": {
    "node": ">=20.* <=22.*"
  },
  "overrides": {
    "i18next-fs-backend": "2.6.4",
    "i18next-http-middleware": "3.9.3"
  },
  "dependencies": {
    "@darwin-node/composer": "^4.3.3",
    "@darwin-node/logger": "^4.3.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.5",
    "node-fetch": "^2.7.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/jest": "^27.5.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "cross-env": "^10.1.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-security": "^1.7.1",
    "jest": "^28.1.3",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^11.2.6",
    "supertest": "^7.2.2",
    "ts-jest": "^28.0.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
